# Copy to .env and set real values. Do not commit secrets.
#
# ENVIRONMENT: development | staging | production
ENVIRONMENT=development

# Database (env_prefix DATABASE_ on DatabaseSettings)
DATABASE_URL=postgresql://user:changeme@localhost:5432/user_service
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Optional; defaults match app/core/config.py if omitted
HOST=0.0.0.0
PORT=8001
UVICORN_RELOAD=false
LOG_LEVEL=INFO
# JSON lines for Filebeat/Logstash/ELK; leave empty for console-only
LOG_JSON_FILE=logs/user-service.jsonl
